<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MBappe.ViewModels.Motivation"
             x:Class="MBappe.Views.Motivation.MotivationView"
             x:DataType="vm:MotivationViewModel">
    <Grid RowDefinitions="Auto,Auto,*"
          Margin="32">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
            <StackPanel Spacing="6">
                <TextBlock Text="Мотивация"
                           Foreground="{StaticResource InkBrush}"
                           FontSize="28"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Расчет бонусов и премий на основе KPI"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="14"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Рассчитать бонус"
                    Classes="primary"
                    Command="{Binding OpenCalculateFormCommand}"
                    IsVisible="{Binding CanCalculateBonuses}"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"/>

            <Button Grid.Column="2"
                    Content="Новая программа"
                    Classes="subtle"
                    Command="{Binding OpenProgramFormCommand}"
                    IsVisible="{Binding CanManageMotivation}"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"/>

            <Button Grid.Column="3"
                    Content="Обновить"
                    Classes="subtle"
                    Command="{Binding RefreshCommand}"
                    VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*,*,*,*"
              Margin="0,24,0,0">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,0,12,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Всего бонусов"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalBonusCount}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,0,12,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Ожидают"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PendingBonusCount}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,0,12,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Утверждено"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ApprovedBonusCount}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,0,12,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Выплачено"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PaidBonusCount}"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="К выплате"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalPayableAmountText}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,430"
              Margin="0,24,0,0">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Margin="0,0,18,0">
                <ListBox ItemsSource="{Binding Bonuses}"
                         SelectedItem="{Binding SelectedBonus}"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:MotivationBonusRowViewModel">
                            <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12">
                                <Grid ColumnDefinitions="1.4*,1.2*,0.95*,0.75*,0.8*,0.9*"
                                      MinHeight="78">
                                    <StackPanel VerticalAlignment="Center"
                                                Spacing="4">
                                        <TextBlock Text="{Binding EmployeeTitle}"
                                                   Foreground="{StaticResource InkBrush}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ProgramTitle}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="4"
                                                Margin="10,0">
                                        <TextBlock Text="{Binding PeriodText}"
                                                   Foreground="{StaticResource InkBrush}"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding CreatedAtText}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Spacing="3">
                                        <TextBlock Text="Эфф."
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding EfficiencyText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3"
                                                VerticalAlignment="Center"
                                                Spacing="3">
                                        <TextBlock Text="База"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding BaseAmountText}"
                                                   Foreground="{StaticResource InkBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4"
                                                VerticalAlignment="Center"
                                                Spacing="3">
                                        <TextBlock Text="Сумма"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding AmountText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="5"
                                                VerticalAlignment="Center"
                                                Spacing="3">
                                        <TextBlock Text="Статус"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding StatusTitle}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,Auto,*">
                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="18">
                    <StackPanel Spacing="13">
                        <TextBlock Text="Действия"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding SelectedBonusCaption}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Выберите бонус в списке, чтобы открыть действия."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding CanShowActionPrompt}"/>

                        <TextBlock Text="Доступен только просмотр своих бонусов."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding IsReadOnlyAccess}"/>

                        <StackPanel Spacing="8"
                                    IsVisible="{Binding CanShowBonusActions}">
                            <Grid ColumnDefinitions="*,*">
                                <Button Content="Утвердить"
                                        Classes="success"
                                        Command="{Binding ApproveSelectedBonusCommand}"
                                        IsEnabled="{Binding CanApproveSelectedBonus}"
                                        HorizontalContentAlignment="Center"
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Выплатить"
                                        Classes="primary"
                                        Command="{Binding PaySelectedBonusCommand}"
                                        IsEnabled="{Binding CanPaySelectedBonus}"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>

                            <TextBox Watermark="Комментарий при отклонении"
                                     Text="{Binding RejectComment}"/>

                            <Grid ColumnDefinitions="*,*">
                                <Button Content="Отклонить"
                                        Classes="danger"
                                        Command="{Binding RejectSelectedBonusCommand}"
                                        IsEnabled="{Binding CanRejectSelectedBonus}"
                                        HorizontalContentAlignment="Center"
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Отменить"
                                        Classes="subtle"
                                        Command="{Binding CancelSelectedBonusCommand}"
                                        IsEnabled="{Binding CanCancelSelectedBonus}"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <Border Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                Padding="10"
                                IsVisible="{Binding HasStatusMessage}">
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="18"
                        Margin="0,18,0,0"
                        IsVisible="{Binding CanShowBonusDetails}">
                    <StackPanel Spacing="13">
                        <TextBlock Text="Карточка бонуса"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Grid ColumnDefinitions="140,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Text="Сотрудник"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedBonus.EmployeeTitle}"
                                       Foreground="{StaticResource InkBrush}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="1"
                                       Text="Программа"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.ProgramTitle}"
                                       Foreground="{StaticResource InkBrush}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2"
                                       Text="Период"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.PeriodText}"
                                       Foreground="{StaticResource InkBrush}"/>

                            <TextBlock Grid.Row="3"
                                       Text="Эффективность"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.EfficiencyText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="4"
                                       Text="Базовая сумма"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.BaseAmountText}"
                                       Foreground="{StaticResource InkBrush}"/>

                            <TextBlock Grid.Row="5"
                                       Text="Расчет"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="5"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.CalculatedAmountText}"
                                       Foreground="{StaticResource InkBrush}"/>

                            <TextBlock Grid.Row="6"
                                       Text="К выплате"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.AmountText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="7"
                                       Text="Статус"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="7"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.StatusTitle}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="8"
                                       Text="Создан"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="8"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.CreatedAtText}"
                                       Foreground="{StaticResource InkBrush}"/>

                            <TextBlock Grid.Row="9"
                                       Text="Комментарий"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Row="9"
                                       Grid.Column="1"
                                       Text="{Binding SelectedBonus.CommentText}"
                                       Foreground="{StaticResource InkBrush}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="18"
                        Margin="0,18,0,0"
                        IsVisible="{Binding IsCalculateFormVisible}">
                    <ScrollViewer>
                        <StackPanel Spacing="10">
                            <TextBlock Text="Расчет бонуса"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Сотрудник"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding EmployeeOptions}"
                                          SelectedItem="{Binding SelectedEmployeeOption}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MotivationEmployeeOption">
                                            <TextBlock Text="{Binding Title}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Программа мотивации"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding ProgramOptions}"
                                          SelectedItem="{Binding SelectedProgramOption}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MotivationProgramOption">
                                            <TextBlock Text="{Binding Title}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4"
                                            Margin="0,0,8,0">
                                    <TextBlock Text="Начало периода"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding PeriodStartText}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Spacing="4">
                                    <TextBlock Text="Конец периода"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding PeriodEndText}"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    IsVisible="{Binding HasCalculateFormMessage}">
                                <TextBlock Text="{Binding CalculateFormMessage}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Grid ColumnDefinitions="*,*">
                                <Button Content="Рассчитать"
                                        Classes="primary"
                                        Command="{Binding CalculateBonusCommand}"
                                        HorizontalContentAlignment="Center"
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Отмена"
                                        Classes="subtle"
                                        Command="{Binding CloseFormsCommand}"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="18"
                        Margin="0,18,0,0"
                        IsVisible="{Binding IsProgramFormVisible}">
                    <ScrollViewer>
                        <StackPanel Spacing="10">
                            <TextBlock Text="Новая программа"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBox Watermark="Название программы"
                                     Text="{Binding NewProgramTitle}"/>

                            <TextBox Watermark="Описание"
                                     Text="{Binding NewProgramDescription}"
                                     AcceptsReturn="True"
                                     MinHeight="70"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Базовая сумма"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBox Text="{Binding NewProgramBaseAmountText}"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Spacing="4"
                                            Margin="0,0,8,0">
                                    <TextBlock Text="Минимальная эффективность, %"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding NewProgramMinEfficiencyText}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Spacing="4">
                                    <TextBlock Text="Максимальная эффективность, %"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding NewProgramMaxEfficiencyText}"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    IsVisible="{Binding HasProgramFormMessage}">
                                <TextBlock Text="{Binding ProgramFormMessage}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Grid ColumnDefinitions="*,*">
                                <Button Content="Создать"
                                        Classes="primary"
                                        Command="{Binding CreateProgramCommand}"
                                        HorizontalContentAlignment="Center"
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Отмена"
                                        Classes="subtle"
                                        Command="{Binding CloseFormsCommand}"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>