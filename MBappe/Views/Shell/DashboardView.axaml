<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MBappe.ViewModels.Shell"
             x:Class="MBappe.Views.Shell.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,*"
              Margin="32">
            <StackPanel Spacing="6">
                <TextBlock Text="{Binding Title}"
                           Foreground="{StaticResource InkBrush}"
                           FontSize="28"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Персональный рабочий контур HR-системы"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="14"/>
            </StackPanel>

            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding Metrics}"
                          Margin="0,26,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DashboardMetricViewModel">
                        <Border Width="245"
                                MinHeight="126"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Padding="18"
                                Margin="0,0,14,14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"/>
                                <TextBlock Text="{Binding Value}"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Caption}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="2"
                  ColumnDefinitions="1.2*,0.8*"
                  Margin="0,10,0,0">
                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="22"
                        Margin="0,0,14,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Текущий пользователь"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="150,*"
                              RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Text="ФИО"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentUser.FullName}"
                                       Foreground="{StaticResource InkBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1"
                                       Text="Логин"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding CurrentUser.Login}"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="2"
                                       Text="Роль"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding RoleTitle}"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="22">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Обновлено"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding UpdatedAt}"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Оболочка готова принимать следующие модули системы без изменения окна входа и навигации."
                                   Foreground="{StaticResource InkBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
